# ─── Supabase ────────────────────────────────────────────────────────────────
# Public (safe in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://gvmxwywuukzptvnttnzv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_Rc5qhrNMyeVsDbIf7VuP_Q_0u81wTvf
# Secret — Supabase dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# ─── Google OAuth (reading users' Google calendars) ─────────────────────────
# Same client configured on the Supabase Google provider.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Google service account (writing to the shared "Life" calendar only) ────
# base64 of the service-account JSON key:  base64 -i service-account.json
GOOGLE_SERVICE_ACCOUNT_KEY=
# The Life calendar's ID (Google Calendar → that calendar → Settings →
# "Integrate calendar" → Calendar ID), shared with the service account email
# OR with the impersonated user below.
LIFE_CALENDAR_ID=
# Optional: enable domain-wide delegation. When set, the SA impersonates this
# Workspace user (who must have "Make changes to events" on the Life calendar).
# Required when the Workspace external-sharing policy blocks granting the SA
# email direct write access. Authorise the SA client ID + the scope
# "https://www.googleapis.com/auth/calendar.events" in Workspace Admin →
# Security → API controls → Domain-wide delegation.
GOOGLE_IMPERSONATE_USER=

# ─── Microsoft 365 (reading Outlook work/school calendars) ──────────────────
# Same app registered on the Supabase Azure provider.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Tenant id, or "organizations" for any work/school account.
MICROSOFT_TENANT_ID=organizations

# ─── Web Push (VAPID) ───────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ─── Misc ───────────────────────────────────────────────────────────────────
# A long random string; Vercel sends it as the cron Authorization header.
CRON_SECRET=
# Production URL (used for links). On Vercel this is inferred automatically.
NEXT_PUBLIC_SITE_URL=https://whereweare.vercel.app
